    {
      "name": "Integration Tests",
      "item": [
        {
          "name": "End-to-End Device Creation Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceName\": \"E2E Test Device\",\n  \"deviceType\": \"test_sensor\",\n  \"firmwareVersion\": \"v1.0.0-test\",\n  \"location\": \"Test Environment\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/subscriber/api/devices",
              "host": ["{{baseUrl}}"],
              "path": ["subscriber", "api", "devices"]
            },
            "description": "End-to-end test for device creation through subscriber proxy"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"E2E Device creation successful\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Created device has all required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('deviceUuid');",
                  "    pm.expect(jsonData).to.have.property('deviceName');",
                  "    pm.expect(jsonData).to.have.property('deviceType');",
                  "    pm.expect(jsonData).to.have.property('firmwareVersion');",
                  "    pm.expect(jsonData).to.have.property('location');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData).to.have.property('createdAt');",
                  "});",
                  "",
                  "pm.test(\"Device data matches input\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.deviceName).to.eql('E2E Test Device');",
                  "    pm.expect(jsonData.deviceType).to.eql('test_sensor');",
                  "    pm.expect(jsonData.firmwareVersion).to.eql('v1.0.0-test');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Cross-Service Communication Test",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/subscriber/api/fetch",
              "host": ["{{baseUrl}}"],
              "path": ["subscriber", "api", "fetch"]
            },
            "description": "Test communication between subscriber and provider services"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Cross-service communication works\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Provider data is accessible via subscriber\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.source).to.eql('provider');",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test(\"Response includes timestamp\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('timestamp');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
