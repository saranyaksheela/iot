{
  "info": {
    "name": "IoT Subscriber API",
    "description": "Comprehensive Postman collection for IoT Subscriber service that acts as a proxy to the Provider service",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "pk_live_subscriber987654321xyz",
      "type": "string"
    },
    {
      "key": "deviceId",
      "value": "1",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-API-Key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{apiKey}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Health check endpoint - no authentication required"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has status field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Service Status",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/subscriber/api/status",
          "host": ["{{baseUrl}}"],
          "path": ["subscriber", "api", "status"]
        },
        "description": "Get subscriber service status - no authentication required"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has service information\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('service');",
              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.expect(jsonData).to.have.property('message');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Device Proxy Operations",
      "item": [
        {
          "name": "Create Device via Proxy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceName\": \"Proxied Temperature Sensor 01\",\n  \"deviceType\": \"temperature_sensor\",\n  \"firmwareVersion\": \"v1.3.0\",\n  \"location\": \"Building C - Floor 2\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/subscriber/api/devices",
              "host": ["{{baseUrl}}"],
              "path": ["subscriber", "api", "devices"]
            },
            "description": "Create a new IoT device via subscriber proxy to provider service"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has device ID\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.environment.set('deviceId', jsonData.id);",
                  "});",
                  "",
                  "pm.test(\"Response has deviceUuid\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('deviceUuid');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Device via Proxy",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceName\": \"Updated Proxied Temperature Sensor 01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/subscriber/api/devices/{{deviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["subscriber", "api", "devices", "{{deviceId}}"]
            },
            "description": "Update an existing device via subscriber proxy"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Device name is updated\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.deviceName).to.eql('Updated Proxied Temperature Sensor 01');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Device via Proxy",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/subscriber/api/devices/{{deviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["subscriber", "api", "devices", "{{deviceId}}"]
            },
            "description": "Delete a device via subscriber proxy"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has success message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Telemetry Proxy Operations",
      "item": [
        {
          "name": "Get Telemetry by Device ID via Proxy",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/subscriber/api/telemetry/device/{{deviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["subscriber", "api", "telemetry", "device", "{{deviceId}}"]
            },
            "description": "Retrieve telemetry data for a specific device via subscriber proxy"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has telemetry array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('telemetry');",
                  "    pm.expect(jsonData.telemetry).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Data Fetch Operations",
      "item": [
        {
          "name": "Fetch Data from Provider",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/subscriber/api/fetch",
              "host": ["{{baseUrl}}"],
              "path": ["subscriber", "api", "fetch"]
            },
            "description": "Fetch data from provider service via subscriber"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has data from provider\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('source');",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test(\"Response indicates provider as source\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.source).to.eql('provider');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
