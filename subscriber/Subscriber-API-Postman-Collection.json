  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Set default headers for all requests",
          "pm.request.headers.add({key: 'User-Agent', value: 'Postman IoT Subscriber API Tests'});",
          "",
          "// Log the request being made",
          "console.log('Making request to: ' + pm.request.url);",
          "",
          "// Set subscriber-specific environment variables if needed",
          "if (!pm.environment.get('subscriberBaseUrl')) {",
          "    pm.environment.set('subscriberBaseUrl', 'http://localhost:8081');",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Global test for response time",
          "pm.test('Response time is less than 10000ms (proxy may be slower)', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(10000);",
          "});",
          "",
          "// Global test for content type on success",
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "    pm.test('Content-Type is application/json', function () {",
          "        pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "    });",
          "}",
          "",
          "// Log response for debugging proxy operations",
          "if (pm.response.code >= 400) {",
          "    console.log('Error response from subscriber service:', pm.response.text());",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ]
}