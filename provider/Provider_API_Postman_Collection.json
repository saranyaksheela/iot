          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"deviceName\": \"Temperature Sensor 1\",\n  \"deviceType\": \"sensor\",\n  \"firmwareVersion\": \"1.0.0\",\n  \"location\": \"Building A - Floor 1\",\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/provider/api/devices",
